{
	"name": "custom-sidebar-icons",
	"version": "2.0.3",
	"description": "Enhance your workspace with customizable icons for documents and folders.",
	"main": "main.js",
	"scripts": {
		"dev": "node scripts/esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production",
		"build:local": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production keep-console && node scripts/copy-to-vault.mjs",
		"version": "pnpm run build && node scripts/version-bump.mjs",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"i18n:typesafe": "typesafe-i18n",
		"i18n:sync": "node scripts/sync-i18n.mjs",
		"test": "jest",
		"test:watch": "jest --watch",
		"link:data": "node scripts/link-data.mjs"
	},
	"keywords": [
		"Obsidian Plugin"
	],
	"author": "RavenHogWarts",
	"license": "GPL-3.0-only",
	"engines": {
		"node": ">=20.16.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"builtin-modules": "5.1.0",
		"dotenv": "^17.4.2",
		"esbuild": "0.28.0",
		"eslint": "^10.2.1",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"fs-extra": "^11.3.4",
		"globals": "^17.5.0",
		"jest": "^30.3.0",
		"obsidian": "^1.12.3",
		"obsidian-typings": "^5.21.0",
		"postcss": "^8.5.12",
		"postcss-nesting": "^14.0.0",
		"ts-jest": "^29.4.9",
		"tslib": "2.8.1",
		"typesafe-i18n": "^5.27.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"lucide-react": "^1.14.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	}
}
